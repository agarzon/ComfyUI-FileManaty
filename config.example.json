{
  "roots": [
    {
      "id": "outputs",
      "label": "Outputs",
      "path": "/absolute/path/to/ComfyUI/output"
    },
    {
      "id": "inputs",
      "label": "Inputs",
      "path": "/absolute/path/to/ComfyUI/input",
      "writable": false
    }
  ],
  "files": {
    "image_extensions": [".png", ".jpg", ".jpeg", ".webp", ".gif", ".bmp", ".avif"],
    "video_extensions": [".mp4", ".webm"],
    "audio_extensions": [".mp3", ".wav", ".ogg", ".m4a", ".flac"]
  },
  "thumbnails": {
    "max_dimension": 320
  },
  "write": {
    "max_upload_mb": 1024
  }
}
